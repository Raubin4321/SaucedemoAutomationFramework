<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">

    <Appenders>
        <!-- Console Logs -->
        <Console name="Console">
            <PatternLayout pattern="%d{HH:mm:ss} [%t] %-5level %c - %msg%n"/>
        </Console>

        <!-- File Logs -->
        <File name="FileLogger" fileName="logs/automationTest.log">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss} [%t] %-5level %c - %msg%n"/>
        </File>
    </Appenders>

    <Loggers>
        <Root level="info">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="FileLogger"/>
        </Root>
    </Loggers>

</Configuration>